        function renderWeeklySchedule() {
            if (!currentUser || currentUser.role !== 'trainer') return;

            const days = getWeekDates(currentWeekOffset);
            const dayNames = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
            const today = new Date().toISOString().split('T')[0];
            const workouts = JSON.parse(localStorage.getItem('gym_workout_assignments')) || [];

            // Update week range label
            const label = document.getElementById('weekRangeLabel');
            if (label) {
                const opts = { month: 'short', day: 'numeric' };
                label.textContent = `${days[0].toLocaleDateString('en-US', opts)} – ${days[6].toLocaleDateString('en-US', opts)}, ${days[0].getFullYear()}`;
            }

            // Build weekly calendar grid
            const grid = document.getElementById('weeklyScheduleGrid');
            if (!grid) return;
            grid.innerHTML = '';

            days.forEach((day, idx) => {
                const dateStr = formatDateStr(day);
                const isToday = dateStr === today;
                const isPast = day < new Date() && !isToday;

                // Get all workouts assigned on this day
                const dayWorkouts = workouts.filter(w => w.date === dateStr);
                const uniqueCategories = [...new Set(dayWorkouts.map(w => w.workoutType))];

                const col = WORKOUT_COLORS[uniqueCategories[0]] || WORKOUT_COLORS['None'];

                const card = document.createElement('div');
                card.style.cssText = `
                    background: ${isToday ? 'linear-gradient(135deg, rgba(255,62,62,0.12), rgba(255,157,0,0.12))' : col.bg};
                    border: ${isToday ? '2px solid rgba(255,62,62,0.5)' : '1px solid ' + col.border};
                    border-radius: 14px;
                    padding: 12px 10px;
                    text-align: center;
                    transition: 0.3s;
                    cursor: ${currentUser.role === 'trainer' ? 'pointer' : 'default'};
                    opacity: ${isPast && !isToday ? '0.7' : '1'};
                    position: relative;
                    min-height: 130px;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    gap: 6px;
                `;

                if (isToday) {
                    const todayBadge = document.createElement('div');
                    todayBadge.style.cssText = 'position: absolute; top: -8px; left: 50%; transform: translateX(-50%); background: var(--primary); color: white; font-size: 0.6rem; font-weight: 800; padding: 2px 10px; border-radius: 20px; white-space: nowrap; letter-spacing: 1px;';
                    todayBadge.textContent = 'TODAY';
                    card.appendChild(todayBadge);
                }

                card.innerHTML += `
                    <div style="font-size: 0.72rem; font-weight: 700; color: ${isToday ? 'var(--primary)' : 'var(--text-dim)'}; text-transform: uppercase; letter-spacing: 1px; margin-top: ${isToday ? '8px' : '0'}">${dayNames[idx]}</div>
                    <div style="font-size: 0.75rem; color: var(--text-dim);">${day.getDate()} ${day.toLocaleDateString('en-US', { month: 'short' })}</div>
                    <div style="font-size: 1.5rem; margin: 4px 0;">${col.icon}</div>
                    <div style="font-size: 0.78rem; font-weight: 700; color: ${col.text};">${uniqueCategories.length > 0 ? uniqueCategories.join(', ') : 'No Plan'}</div>
                    <div style="font-size: 0.68rem; color: var(--text-dim);">${dayWorkouts.length > 0 ? dayWorkouts.length + ' member(s)' : 'Unassigned'}</div>
                `;

                grid.appendChild(card);
            });

            // Build assignment log table
            const tbody = document.getElementById('weeklyAssignmentLogBody');
            if (!tbody) return;
            tbody.innerHTML = '';

            if (members.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" style="text-align: center; color: var(--text-dim);">No members registered.</td></tr>';
                return;
            }

            members.forEach(m => {
                const cells = days.map(day => {
                    const dateStr = formatDateStr(day);
                    const w = workouts.find(x => x.memberId == m.id && x.date === dateStr);
                    if (!w) return '<td style="text-align:center; color: var(--text-dim); font-size:0.75rem;">—</td>';
                    const col = WORKOUT_COLORS[w.workoutType] || WORKOUT_COLORS['None'];
                    return `<td style="text-align:center;"><span style="background:${col.bg}; color:${col.text}; font-size:0.7rem; font-weight:700; padding:3px 8px; border-radius:8px; white-space:nowrap;">${col.icon} ${w.workoutType}</span></td>`;
                }).join('');

                tbody.insertAdjacentHTML('beforeend', `<tr>
                    <td style="font-weight:600; white-space:nowrap;">${m.name}<br><span style="font-size:0.7rem; color:var(--text-dim); font-weight:normal;">${m.email}</span></td>
