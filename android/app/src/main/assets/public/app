        function confirmBooking() {
            bookingData.date = document.getElementById('bookingDate').value;
            if (!bookingData.date || !bookingData.session || bookingData.machines.length === 0 || !bookingData.time) {
                return showToast('Complete all steps: date, session, at least one machine, and time!');
            }

            const date = bookingData.date;
            const machines_sel = bookingData.machines;
            const time = bookingData.time;

            const hasExisting = bookings.some(b => b.memberEmail === currentUser.data.email && b.date === date);
            if (hasExisting) {
                return showToast('Error: You already have a session booked for this date!');
            }

            // Check each selected machine capacity
            for (const machine of machines_sel) {
                const machineBookings = bookings.filter(b => {
                    const bMachines = Array.isArray(b.machines) ? b.machines : [b.machine];
                    return b.date === date && bMachines.includes(machine) && b.time === time;
                }).length;
                if (machineBookings >= 4) {
                    return showToast(`Error: ${machine} is fully booked for this time slot!`);
                }
            }

            const totalBookings = bookings.filter(b => b.date === date && b.time === time).length;
            if (totalBookings >= 15) {
                return showToast('Error: The gym has reached maximum occupancy for this time slot!');
            }

            const newBooking = {
                ...bookingData,
                machines: machines_sel,
                machine: machines_sel.join(', '), // legacy compat field
                id: 'BK' + Date.now(),
                memberEmail: currentUser.data.email,
                status: 'Booked'
            };

            bookings.push(newBooking);
            localStorage.setItem('gym_bookings', JSON.stringify(bookings));

            // Update Modal
            document.getElementById('sumDate').textContent = bookingData.date;
            document.getElementById('sumSession').textContent = bookingData.session;
            document.getElementById('sumMachine').textContent = machines_sel.join(', ');
            document.getElementById('sumTime').textContent = bookingData.time;
            document.getElementById('summaryModal').style.display = 'flex';

            updateDashboardUI();
            showToast('Slot Booked Successfully!');
        }

