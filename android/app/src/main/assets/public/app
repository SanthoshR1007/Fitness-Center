        function updateTimeSlotsGrid() {
            const date = document.getElementById('bookingDate').value || new Date().toISOString().split('T')[0];
            const session = bookingData.session;
            if (!session) return;

            const sessionMachines = machines[session] || [];

            document.querySelectorAll('#timeGrid .select-item').forEach(item => {
                const time = item.textContent.trim();

                const totalBookings = bookings.filter(b => b.date === date && b.time === time).length;
                const totalCapacity = 15;

                const availableMachines = sessionMachines.filter(machine => {
                    const count = bookings.filter(b => {
                        const bMachines = Array.isArray(b.machines) ? b.machines : [b.machine];
                        return b.date === date && bMachines.includes(machine) && b.time === time;
                    }).length;
                    return count < 4;
                });

                item.classList.remove('active', 'full');
                item.onclick = () => selectTime(time, item);

                if (totalBookings >= totalCapacity || availableMachines.length === 0) {
                    item.classList.add('full');
                    item.onclick = null;
                }
            });
        }

        function selectSession(session) {
            bookingData.session = session;
            document.querySelectorAll('#sessionGrid .select-item').forEach(el => el.classList.toggle('active', el.textContent.trim() === session));

            bookingData.machines = [];
            bookingData.time = '';
            document.querySelectorAll('#timeGrid .select-item').forEach(i => i.classList.remove('active'));
            document.getElementById('selectedMachinesSummary').style.display = 'none';
            document.getElementById('selectedMachinesText').textContent = '';

            document.getElementById('timeStep').style.display = 'block';
            document.getElementById('machineStep').style.display = 'none';

            updateTimeSlotsGrid();
        }

        function updateMachineGrid() {
            const mGrid = document.getElementById('machineGrid');
            if (!mGrid) return;
            mGrid.innerHTML = '';

            const session = bookingData.session;
            const time = bookingData.time;
            const date = document.getElementById('bookingDate').value || new Date().toISOString().split('T')[0];
            if (!session || !time) return;

            const sessionMachines = machines[session] || [];

            sessionMachines.forEach(mName => {
                const count = bookings.filter(b => {
                    const bMachines = Array.isArray(b.machines) ? b.machines : [b.machine];
                    return b.date === date && bMachines.includes(mName) && b.time === time;
                }).length;

                const capacity = 4;
                const isFull = count >= capacity;

                const item = document.createElement('div');
                item.className = 'select-item';
                if (isFull) {
                    item.classList.add('full');
                    item.textContent = `${mName} (FULL)`;
                } else {
                    item.textContent = `${mName} (${count}/${capacity})`;
                    item.onclick = () => selectMachine(mName, item);
                }
                mGrid.appendChild(item);
            });
        }

        function selectMachine(machine, el) {
            const idx = bookingData.machines.indexOf(machine);
            if (idx === -1) {
                bookingData.machines.push(machine);
                el.classList.add('active');
            } else {
                bookingData.machines.splice(idx, 1);
                el.classList.remove('active');
            }

            const summary = document.getElementById('selectedMachinesSummary');
            const text = document.getElementById('selectedMachinesText');
            if (bookingData.machines.length > 0) {
                text.textContent = bookingData.machines.join(', ');
                summary.style.display = 'block';
            } else {
                summary.style.display = 'none';
            }
        }

        function switchPage(pageId) {
            // Strict Role-Based Access Control (RBAC) guards
            const adminPages = ['admin-dashboard', 'admin-members', 'admin-memberships', 'admin-payments', 'admin-trainers', 'admin-machines', 'admin-attendance', 'admin-settings', 'admin-accounts'];
            const trainerPages = ['trainer-dashboard', 'weekly-schedule'];
            const memberPages = ['dashboard', 'booking', 'member-membership', 'member-weekly-workout', 'profile', 'notifications'];

            if (!currentUser) {
                document.getElementById('authScreen').style.display = 'flex';
                return;
            }

            if (adminPages.includes(pageId) && currentUser.role !== 'admin') {
                showToast('❌ Unauthorized: Admin access required.');
                switchPage(currentUser.role === 'trainer' ? 'trainer-dashboard' : 'dashboard');
                return;
            }

            if (trainerPages.includes(pageId) && currentUser.role !== 'trainer') {
                showToast('❌ Unauthorized: Trainer access required.');
                switchPage(currentUser.role === 'admin' ? 'admin-dashboard' : 'dashboard');
                return;
            }

            if (memberPages.includes(pageId) && currentUser.role !== 'member') {
                showToast('❌ Unauthorized: Member access required.');
                switchPage(currentUser.role === 'admin' ? 'admin-dashboard' : 'trainer-dashboard');
                return;
            }

            document.querySelectorAll('.page-section').forEach(p => p.classList.remove('active'));
            const targetPage = document.getElementById(pageId);
            if (targetPage) targetPage.classList.add('active');

