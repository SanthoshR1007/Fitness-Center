        function assignWorkoutCategory(memberId, category) {
            if (!currentUser || (currentUser.role !== 'trainer' && currentUser.role !== 'admin')) {
                showToast('❌ Unauthorized Action!');
                return;
            }
            const idx = members.findIndex(m => m.id == memberId);
            if (idx === -1) return;
            members[idx].assignedWorkout = category;
            localStorage.setItem('gym_members', JSON.stringify(members));
            showToast(`Assigned ${category} to ${members[idx].name}`);

            if (currentUser && currentUser.role === 'member' && currentUser.data.id == memberId) {
                currentUser.data.assignedWorkout = category;
                localStorage.setItem('gym_session', JSON.stringify(currentUser));
            }
        }

