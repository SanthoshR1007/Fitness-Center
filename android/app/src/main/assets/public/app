        function createAccountChip(name, id, pass, role) {
            const item = document.createElement('div');
            item.className = 'saved-account-chip';
            item.style = "background: rgba(255,255,255,0.05); padding: 10px 15px; border-radius: 12px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; border: 1px solid var(--card-border); transition: 0.3s; margin-bottom: 5px;";
            item.innerHTML = `
                <div style="flex: 1; text-align: left;" onclick="autofillAccount('${id}', '${pass}', '${role}')">
                    <p style="font-size: 0.85rem; font-weight: 700; color: var(--primary); margin: 0;">${name}</p>
                    <p style="font-size: 0.7rem; color: var(--text-dim); margin: 0;">${id}</p>
                </div>
                <div onclick="event.stopPropagation(); removeSavedAccount('${id}', '${role}')" style="padding: 5px; opacity: 0.6; transition: 0.3s;">
                    <i data-lucide="x" style="width: 14px;"></i>
                </div>
            `;
            item.onclick = () => autofillAccount(id, pass, role);

            item.onmouseenter = () => {
                item.style.borderColor = 'var(--primary)';
                item.style.background = 'rgba(255, 62, 62, 0.08)';
                item.style.transform = 'translateX(5px)';
            };
            item.onmouseleave = () => {
                item.style.borderColor = 'var(--card-border)';
                item.style.background = 'rgba(255,255,255,0.05)';
                item.style.transform = 'translateX(0)';
            };

            return item;
        }

        function autofillAccount(id, pass, role) {
            let idField, passField;
            if (role === 'admin') {
                idField = document.getElementById('adminID');
                passField = document.getElementById('adminPass');
                setAuthMode('admin');
            } else if (role === 'trainer') {
                idField = document.getElementById('trainerID');
                passField = document.getElementById('trainerPass');
                setAuthMode('trainer');
            } else {
                idField = document.getElementById('loginEmail');
                passField = document.getElementById('loginPass');
                setAuthMode('member');
            }

            idField.value = id;
            passField.value = pass;

            [idField, passField].forEach(f => {
                f.style.borderColor = 'var(--primary)';
                f.style.background = 'rgba(255, 62, 62, 0.15)';
                setTimeout(() => {
                    f.style.borderColor = 'var(--card-border)';
                    f.style.background = 'rgba(255, 255, 255, 0.05)';
                }, 600);
            });
        }

        function removeSavedAccount(id, role) {
            let key;
            if (role === 'admin') key = 'gym_multi_saved_admins';
            else if (role === 'trainer') key = 'gym_multi_saved_trainers';
            else key = 'gym_multi_saved_accounts';
            let saved = JSON.parse(localStorage.getItem(key)) || [];
            saved = saved.filter(a => (a.email || a.phone || a.id) !== id);
            localStorage.setItem(key, JSON.stringify(saved));
            renderSavedAccounts();
        }

