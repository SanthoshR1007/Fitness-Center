        // ── Save Login Credentials (without logging in) ──────────────────────
        function saveLoginCredentials(role) {
            let id, pass, name;

            if (role === 'member') {
                id = document.getElementById('loginEmail').value.trim();
                pass = document.getElementById('loginPass').value;
                if (!id || !pass) { showToast('⚠️ Enter Email and Password before saving.'); return; }

                // Verify member exists
                const member = members.find(m => m.email.toLowerCase() === id.toLowerCase());
                if (!member) { showToast('❌ No member found with this email. Cannot save.'); return; }
                name = member.name;

                let saved = JSON.parse(localStorage.getItem('gym_multi_saved_accounts')) || [];
                if (saved.find(a => a.email.toLowerCase() === id.toLowerCase())) {
                    // Update password if it already exists
                    saved = saved.map(a => a.email.toLowerCase() === id.toLowerCase() ? { ...a, password: pass } : a);
                    localStorage.setItem('gym_multi_saved_accounts', JSON.stringify(saved));
                    showToast('✅ Saved credentials updated for ' + name + '!');
                } else {
                    saved.push({ name, email: id, password: pass });
                    localStorage.setItem('gym_multi_saved_accounts', JSON.stringify(saved));
                    showToast('✅ Login saved for ' + name + '! Tap chip to auto-fill.');
                }

            } else if (role === 'trainer') {
                id = document.getElementById('trainerID').value.trim();
                pass = document.getElementById('trainerPass').value;
                if (!id || !pass) { showToast('⚠️ Enter Email/Phone and Password before saving.'); return; }

                // Verify trainer exists
                const trainers = JSON.parse(localStorage.getItem('gym_trainers')) || [];
                const trainer = trainers.find(t =>
                    (t.email && t.email.toLowerCase() === id.toLowerCase()) ||
                    (t.phone && t.phone === id) ||
                    (t.id && t.id === id)
                );
                if (!trainer) { showToast('❌ No trainer found with this ID/email/phone. Cannot save.'); return; }
                name = trainer.name;

                let saved = JSON.parse(localStorage.getItem('gym_multi_saved_trainers')) || [];
                const existsIdx = saved.findIndex(a =>
                    (a.email && a.email.toLowerCase() === id.toLowerCase()) || (a.phone && a.phone === id)
                );
                if (existsIdx !== -1) {
                    saved[existsIdx].password = pass;
                    localStorage.setItem('gym_multi_saved_trainers', JSON.stringify(saved));
                    showToast('✅ Saved credentials updated for ' + name + '!');
                } else {
                    saved.push({ name, email: trainer.email || id, phone: trainer.phone || id, password: pass });
                    localStorage.setItem('gym_multi_saved_trainers', JSON.stringify(saved));
                    showToast('✅ Trainer login saved for ' + name + '! Tap chip to auto-fill.');
                }

            } else if (role === 'admin') {
                id = document.getElementById('adminID').value.trim();
                pass = document.getElementById('adminPass').value;
                if (!id || !pass) { showToast('⚠️ Enter Admin ID and Password before saving.'); return; }

                // Verify admin exists
                const admins = JSON.parse(localStorage.getItem('gym_admins')) || [];
                const admin = admins.find(a => a.id === id);
                if (!admin) { showToast('❌ No admin found with this ID. Cannot save.'); return; }
                name = admin.name;

                let saved = JSON.parse(localStorage.getItem('gym_multi_saved_admins')) || [];
                const existsIdx = saved.findIndex(a => a.id === id);
                if (existsIdx !== -1) {
                    saved[existsIdx].password = pass;
                    localStorage.setItem('gym_multi_saved_admins', JSON.stringify(saved));
                    showToast('✅ Saved credentials updated for ' + name + '!');
                } else {
                    saved.push({ name, id, password: pass });
                    localStorage.setItem('gym_multi_saved_admins', JSON.stringify(saved));
                    showToast('✅ Admin login saved for ' + name + '! Tap chip to auto-fill.');
                }
            }

            // Immediately refresh the saved chips so user sees the result now
            renderSavedAccounts();
        }


