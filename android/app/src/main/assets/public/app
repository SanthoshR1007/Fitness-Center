        async function saveEditMember() {
            if (!currentUser || currentUser.role !== 'admin') return showToast('❌ Unauthorized Action!');
            const id = document.getElementById('editMemId').value;
            const mIndex = members.findIndex(mem => mem.id == id);
            if (mIndex === -1) return;

            const inputPass = document.getElementById('editMemPass').value;
            let hashedPassword = members[mIndex].password;

            if (inputPass && inputPass !== members[mIndex].password) {
