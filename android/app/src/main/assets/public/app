        async function handleLogin() {
            const err = document.getElementById('authError');
            if (authMode === 'admin') {
                const id = document.getElementById('adminID').value.trim();
                const pass = document.getElementById('adminPass').value;

                let adminAccounts = JSON.parse(localStorage.getItem('gym_admins')) || [];

                if (adminAccounts.length === 0) {
                    err.textContent = 'No admin account exists. Please create one first!';
                    showAuthError();
                    return;
                }

                let admin = null;
                for (const a of adminAccounts) {
                    if (a.id === id && (await verifyPassword(pass, a.password))) {
                        admin = a;
                        break;
                    }
                }

                if (admin) {
                    currentUser = { role: 'admin', name: admin.name, adminId: admin.id };
                    startApp();
                } else {
                    err.textContent = 'Admin ID or Password is incorrect!';
                    showAuthError();
                }
            } else if (authMode === 'trainer') {
                const loginInput = document.getElementById('trainerID').value.trim();
                const pass = document.getElementById('trainerPass').value;

                let trainersList = JSON.parse(localStorage.getItem('gym_trainers')) || [];
                let trainer = null;
                for (const t of trainersList) {
                    const emailMatch = t.email && t.email.toLowerCase() === loginInput.toLowerCase();
                    const phoneMatch = t.phone && t.phone === loginInput;
                    const idMatch = t.id && t.id === loginInput;
                    if ((emailMatch || phoneMatch || idMatch) && (await verifyPassword(pass, t.password))) {
                        trainer = t;
                        break;
                    }
                }

                if (trainer) {
                    currentUser = { role: 'trainer', name: trainer.name, trainerId: trainer.id, email: trainer.email };
                    startApp();
                } else {
                    err.textContent = 'Email / Phone or Password is incorrect!';
                    showAuthError();
                }
            } else {
                const email = document.getElementById('loginEmail').value.trim();
                const pass = document.getElementById('loginPass').value;

                let user = null;
                for (const m of members) {
                    if (m.email === email && (await verifyPassword(pass, m.password) || m.mobile === pass)) {
                        user = m;
                        break;
                    }
                }

                if (user) {
                    currentUser = { role: 'member', data: user };
                    startApp();
                } else {
                    err.textContent = 'Member not found! Contact your administrator.';
                    showAuthError();
                }
            }
        }

