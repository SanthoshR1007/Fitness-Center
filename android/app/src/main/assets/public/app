        function recordPayment() {
            if (!currentUser || currentUser.role !== 'admin') return showToast('❌ Unauthorized Action!');
            const email = document.getElementById('paymentMemberSelect').value;
            const amount = document.getElementById('paymentAmount').value;
            const plan = document.getElementById('paymentPlan').value;
            const method = document.getElementById('paymentMethod').value;
            const dateInput = document.getElementById('paymentDate').value || new Date().toISOString().split('T')[0];

            if (!email || !amount || !dateInput) {
                return showToast('❌ Fill all details to record payment.');
            }

            const mIndex = members.findIndex(m => m.email === email);
            if (mIndex === -1) return showToast('❌ Selected member not found.');

            const startDate = new Date(dateInput);
            let endDate = new Date(startDate);
            if (plan === 'Monthly') endDate.setMonth(endDate.getMonth() + 1);
            else if (plan === 'Quarterly') endDate.setMonth(endDate.getMonth() + 3);
            else if (plan === 'Half-Yearly') endDate.setMonth(endDate.getMonth() + 6);
            else if (plan === 'Yearly') endDate.setFullYear(endDate.getFullYear() + 1);

            const startStr = dateInput;
            const endStr = endDate.toISOString().split('T')[0];

            members[mIndex].membershipPlan = plan;
            members[mIndex].membershipStart = startStr;
            members[mIndex].membershipEnd = endStr;
            members[mIndex].membershipStatus = 'Active';
            localStorage.setItem('gym_members', JSON.stringify(members));

            let payments = JSON.parse(localStorage.getItem('gym_payments')) || [];
            const newPayment = {
                id: 'PM' + Date.now(),
                memberEmail: email,
                memberName: members[mIndex].name,
                amount: Number(amount),
                plan: plan,
                date: startStr,
                method: method,
                status: 'Paid'
            };
            payments.push(newPayment);
            localStorage.setItem('gym_payments', JSON.stringify(payments));

            showToast('✅ Transaction Recorded & Membership Activated!');
            closeRecordPaymentModal();
            updateAdminPanels();
        }

