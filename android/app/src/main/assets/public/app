<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title id="appTitle">Dragon Gym | Unified Management</title>
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#ff3e3e">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="dragon_gym_icon.png">

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary: #ff3e3e;
            --secondary: #ff9d00;
            --bg-dark: #0a0b10;
            --card-bg: rgba(255, 255, 255, 0.04);
            --card-border: rgba(255, 255, 255, 0.08);
            --text-main: #ffffff;
            --text-dim: #909090;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Outfit', sans-serif;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            overflow: hidden;
        }

        /* Sidebar */
        nav.sidebar {
            width: 260px;
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(20px);
            border-right: 1px solid var(--card-border);
            padding: 2rem;
            display: flex;
            flex-direction: column;
            gap: 2rem;
            flex-shrink: 0;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .nav-links {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .nav-item {
            padding: 12px 16px;
            border-radius: 12px;
            color: var(--text-dim);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: 0.3s;
            cursor: pointer;
            border: 1px solid transparent;
        }

        .nav-item.active {
            background: rgba(255, 62, 62, 0.1);
            color: var(--primary);
            border: 1px solid rgba(255, 62, 62, 0.2);
        }

        .nav-item:hover:not(.active) {
            color: var(--primary);
            background: rgba(255, 255, 255, 0.05);
        }

        /* Main Content */
        main.content-area {
            flex: 1;
            overflow-y: auto;
            padding: 3rem;
            scroll-behavior: smooth;
        }

        .page-section {
            display: none;
            animation: fadeIn 0.4s ease-out;
        }

        .page-section.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        header {
            margin-bottom: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 24px;
            padding: 1.5rem;
        }

        .btn-primary {
            background: linear-gradient(45deg, var(--primary), var(--secondary));
            border: none;
            padding: 12px 24px;
            border-radius: 12px;
            color: white;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 62, 62, 0.3);
        }

        /* Grid Layouts */
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
        }

        .grid-selection {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 1rem;
        }

        /* Selection Items */
        .select-item {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--card-border);
            padding: 1.2rem;
            border-radius: 20px;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
        }

        .select-item:hover {
            border-color: var(--primary);
        }

        .select-item.active {
            background: rgba(255, 62, 62, 0.1);
            border-color: var(--primary);
            color: var(--primary);
            font-weight: 600;
        }

        .select-item.full {
            border-color: #ff3e3e;
            color: #ff3e3e;
            background: rgba(255, 62, 62, 0.1);
            cursor: not-allowed;
            opacity: 0.9;
            position: relative;
        }

        .select-item.full::after {
            content: 'FULL';
            position: absolute;
            bottom: 5px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.6rem;
            font-weight: 800;
        }

        /* Toast & Modal */
        .toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: linear-gradient(45deg, var(--primary), var(--secondary));
            color: white;
            padding: 1rem 2rem;
            border-radius: 12px;
            display: none;
            z-index: 2000;
            font-weight: 700;
        }

        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(10px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .modal {
            background: var(--bg-dark);
            border: 1px solid var(--card-border);
            padding: 2.5rem;
            border-radius: 30px;
            width: 500px;
            text-align: center;
        }

        /* Form Styles */
        .form-group {
            margin-bottom: 1.5rem;
            text-align: left;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-dim);
            font-size: 0.9rem;
        }

        .form-group input {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--card-border);
            padding: 12px;
            border-radius: 12px;
            color: white;
            outline: none;
        }

        .form-group input:focus {
            border-color: var(--primary);
        }

        /* Login Screen */
        .auth-container {
            position: fixed;
            inset: 0;
            background: linear-gradient(rgba(10, 11, 16, 0.8), rgba(10, 11, 16, 0.8)), url('gym_login_bg.png');
            background-size: cover;
            background-position: center;
            z-index: 5000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .auth-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid var(--card-border);
            padding: 3rem;
            border-radius: 30px;
            width: 420px;
            text-align: center;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        /* Dashboard Background */
        .app-container {
            display: flex;
            height: 100vh;
            width: 100vw;
            background: linear-gradient(rgba(10, 11, 16, 0.95), rgba(10, 11, 16, 0.95)), url('gym_dashboard_bg.png');
            background-size: cover;
            background-position: center;
        }

        .auth-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 2rem;
            background: rgba(255, 255, 255, 0.05);
            padding: 5px;
            border-radius: 12px;
        }

        .auth-tab {
            flex: 1;
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
            color: var(--text-dim);
            transition: 0.3s;
        }

        .auth-tab.active {
            background: var(--primary);
            color: white;
        }

        /* Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

        th {
            text-align: left;
            padding: 12px;
            color: var(--text-dim);
            font-size: 0.85rem;
            border-bottom: 1px solid var(--card-border);
        }

        td {
            padding: 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.02);
            font-size: 0.9rem;
        }

        .status-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
        }

        .status-present {
            background: rgba(0, 255, 128, 0.1);
            color: #00ff80;
        }

        .status-absent {
            background: rgba(255, 62, 62, 0.1);
            color: var(--primary);
        }

        .machine-full {
            color: #ff3e3e;
            font-weight: 700;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% {
                opacity: 1;
            }

            50% {
                opacity: 0.5;
            }

            100% {
                opacity: 1;
            }
        }

        /* Hidden for role */
        .admin-only,
        .member-only,
        .trainer-only {
            display: none;
        }

        /* Mobile Responsive & Sidebar Drawer */
        .mobile-header {
            display: none;
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--card-border);
            padding: 1rem 1.5rem;
            align-items: center;
            justify-content: space-between;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 60px;
            z-index: 3000;
        }

        .hamburger-btn {
            background: transparent;
            border: none;
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .drawer-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(5px);
            z-index: 3999;
        }

        @media (max-width: 768px) {
            body {
                overflow-x: hidden;
                overflow-y: auto;
            }

            .app-container {
                flex-direction: column;
                height: auto;
                min-height: 100vh;
                padding-top: 60px;
                /* Offset for mobile header */
            }

            nav.sidebar {
                position: fixed;
                top: 0;
                left: -270px;
                width: 260px;
                height: 100vh;
                z-index: 4000;
                transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                border-right: 1px solid var(--card-border);
                box-shadow: 10px 0 30px rgba(0, 0, 0, 0.5);
            }

            nav.sidebar.drawer-open {
                left: 0;
            }

            main.content-area {
                padding: 1.5rem;
                overflow-y: visible;
            }

            .mobile-header {
                display: flex;
            }

            .grid-3 {
                grid-template-columns: 1fr;
            }

            .grid-selection {
                grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            }

            .modal {
                width: 90%;
                padding: 1.5rem;
            }

            #weeklyScheduleGrid,
            #memberWeeklyGrid {
                grid-template-columns: repeat(4, 1fr) !important;
                gap: 8px !important;
            }
        }

        @media (max-width: 480px) {

            #weeklyScheduleGrid,
            #memberWeeklyGrid {
                grid-template-columns: repeat(3, 1fr) !important;
                gap: 6px !important;
            }
        }
    </style>
</head>

<body>
    <div id="toast" class="toast">Action successful!</div>

    <!-- Auth Screen -->
    <div id="authScreen" class="auth-container">
        <div class="auth-card">
            <div class="logo" style="justify-content: center; margin-bottom: 2rem;"><i data-lucide="shield"></i> <span
                    class="gym-name-text">Dragon Gym</span></div>
            <div class="auth-tabs">
                <div class="auth-tab active" onclick="setAuthMode('member')">Member</div>
                <div class="auth-tab" onclick="setAuthMode('trainer')">Trainer</div>
                <div class="auth-tab" onclick="setAuthMode('admin')">Admin</div>
            </div>

            <div id="memberFields">
                <div id="savedAccountsSection" style="margin-bottom: 1.5rem; display: none;">
                    <p style="font-size: 0.75rem; color: var(--text-dim); margin-bottom: 0.5rem; text-align: left;">
                        Saved Accounts:</p>
                    <div id="savedAccountsList" style="display: flex; flex-direction: column; gap: 8px;"></div>
                </div>
                <div class="form-group">
                    <label>Email ID</label>
                    <input type="email" id="loginEmail" placeholder="Enter Member Email">
                </div>
                <div class="form-group">
                    <label>Password / Mobile</label>
                    <input type="password" id="loginPass" placeholder="Enter Password">
                </div>
                <button type="button" onclick="saveLoginCredentials('member')" style="
                    width: 100%; padding: 10px; margin-bottom: 0.5rem;
                    background: rgba(255,255,255,0.05);
                    border: 1px dashed rgba(255,255,255,0.2);
                    color: var(--text-dim); border-radius: 12px;
                    font-size: 0.82rem; cursor: pointer; transition: 0.3s;
                    display: flex; align-items: center; justify-content: center; gap: 6px;"
                    onmouseover="this.style.background='rgba(255,62,62,0.1)'; this.style.borderColor='rgba(255,62,62,0.3)'; this.style.color='var(--primary)';"
                    onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.borderColor='rgba(255,255,255,0.2)'; this.style.color='var(--text-dim)';">
                    💾 Save Login
                </button>
            </div>

            <div id="trainerFields" style="display: none;">
                <div id="savedTrainerSection" style="margin-bottom: 1.5rem; display: none;">
                    <p style="font-size: 0.75rem; color: var(--text-dim); margin-bottom: 0.5rem; text-align: left;">
                        Saved Trainer Accounts:</p>
                    <div id="savedTrainerList" style="display: flex; flex-direction: column; gap: 8px;"></div>
                </div>
                <div class="form-group">
                    <label>Email Address / Phone Number</label>
                    <input type="text" id="trainerID" placeholder="Enter Email or Phone">
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" id="trainerPass" placeholder="••••••••">
                </div>
                <button type="button" onclick="saveLoginCredentials('trainer')" style="
                    width: 100%; padding: 10px; margin-bottom: 0.5rem;
                    background: rgba(255,255,255,0.05);
                    border: 1px dashed rgba(255,255,255,0.2);
                    color: var(--text-dim); border-radius: 12px;
                    font-size: 0.82rem; cursor: pointer; transition: 0.3s;
                    display: flex; align-items: center; justify-content: center; gap: 6px;"
                    onmouseover="this.style.background='rgba(255,62,62,0.1)'; this.style.borderColor='rgba(255,62,62,0.3)'; this.style.color='var(--primary)';"
                    onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.borderColor='rgba(255,255,255,0.2)'; this.style.color='var(--text-dim)';">
                    💾 Save Login
                </button>
            </div>

            <div id="adminFields" style="display: none;">
                <div id="savedAdminSection" style="margin-bottom: 1.5rem; display: none;">
                    <p style="font-size: 0.75rem; color: var(--text-dim); margin-bottom: 0.5rem; text-align: left;">
                        Saved Admin Accounts:</p>
                    <div id="savedAdminList" style="display: flex; flex-direction: column; gap: 8px;"></div>
                </div>
                <div class="form-group">
                    <label>Admin ID</label>
                    <input type="text" id="adminID" placeholder="Enter Admin ID">
                </div>
                <div class="form-group">
                    <label>Admin Password</label>
                    <input type="password" id="adminPass" placeholder="••••••••">
                </div>
                <button type="button" onclick="saveLoginCredentials('admin')" style="
                    width: 100%; padding: 10px; margin-bottom: 0.5rem;
                    background: rgba(255,255,255,0.05);
                    border: 1px dashed rgba(255,255,255,0.2);
                    color: var(--text-dim); border-radius: 12px;
                    font-size: 0.82rem; cursor: pointer; transition: 0.3s;
                    display: flex; align-items: center; justify-content: center; gap: 6px;"
                    onmouseover="this.style.background='rgba(255,62,62,0.1)'; this.style.borderColor='rgba(255,62,62,0.3)'; this.style.color='var(--primary)';"
                    onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.borderColor='rgba(255,255,255,0.2)'; this.style.color='var(--text-dim)';">
                    💾 Save Login
                </button>
                <!-- First-time setup banner: only shown when no admin accounts exist -->
                <div id="firstTimeSetupBanner"
                    style="display:none; margin-bottom: 1rem; padding: 1rem; background: rgba(255,157,0,0.08); border: 1px solid rgba(255,157,0,0.25); border-radius: 14px;">
                    <p style="font-size:0.8rem; color:var(--secondary); margin-bottom:0.75rem;">⚙️ No admin account
                        found. Set up your first admin to get started.</p>
                    <button class="btn-primary"
                        style="width:100%; padding:10px; background: linear-gradient(135deg,#ff9d00,#ff3e3e);"
                        onclick="openSetupAdmin()">Create First Admin Account</button>
                </div>
            </div>

            <div
                style="display: flex; align-items: center; gap: 8px; margin-bottom: 1.5rem; justify-content: flex-start;">
                <input type="checkbox" id="rememberMe" style="width: 16px; height: 16px; accent-color: var(--primary);">
                <label for="rememberMe" style="font-size: 0.85rem; color: var(--text-dim); cursor: pointer;">Remember Me
                    / Save Login</label>
            </div>

            <button class="btn-primary" style="width: 100%; padding: 15px;" onclick="handleLogin()">Enter The
                Arena</button>
            <div id="authSignupAction"
                style="margin-top: 1.2rem; font-size: 0.85rem; text-align: center; color: var(--text-dim);">
                Don't have an account? <span onclick="showMemberSignupInfo()"
                    style="color: var(--primary); font-weight: 600; cursor: pointer; text-decoration: underline;">Sign
                    Up</span>
            </div>
            <p id="authError" style="color: var(--primary); font-size: 0.8rem; margin-top: 1rem; display: none;">User
                Not Found!</p>
        </div>
    </div>

    <!-- Booking Summary Modal -->
    <div id="summaryModal" class="modal-overlay">
        <div class="modal">
            <h2 style="margin-bottom: 1.5rem;">Booking Confirmed!</h2>
            <div id="summaryDetails"
                style="text-align: left; background: rgba(255,255,255,0.02); padding: 1.5rem; border-radius: 20px; margin-bottom: 2rem;">
                <p>Date: <span id="sumDate" style="color: var(--primary); font-weight: 600;">-</span></p>
                <p>Session: <span id="sumSession" style="color: var(--primary); font-weight: 600;">-</span></p>
                <p>Machine: <span id="sumMachine" style="color: var(--primary); font-weight: 600;">-</span></p>
                <p>Time: <span id="sumTime" style="color: var(--primary); font-weight: 600;">-</span></p>
                <p>Status: <span style="color: #00ff80; font-weight: 700;">Confirmed</span></p>
            </div>
            <button class="btn-primary" style="width: 100%;" onclick="closeModal()">Back to Dashboard</button>
        </div>
    </div>

    <!-- Mobile Header Top Bar -->
    <div class="mobile-header">
        <button class="hamburger-btn" onclick="toggleSidebarDrawer(true)">
            <i data-lucide="menu"></i>
        </button>
        <div class="logo" style="margin-bottom: 0; font-size: 1.2rem;"><i data-lucide="shield"></i> <span
                class="gym-name-text">Dragon Gym</span></div>
        <div style="width: 24px;"></div> <!-- Spacer -->
    </div>

    <!-- Drawer Backdrop Overlay -->
    <div id="drawerBackdrop" class="drawer-backdrop" onclick="toggleSidebarDrawer(false)"></div>

    <div class="app-container">
        <nav class="sidebar" id="appSidebar">
            <div class="logo" id="gymLogo"><i data-lucide="shield"></i> <span class="gym-name-text">Dragon Gym</span>
            </div>
            <ul class="nav-links">
                <!-- Shared or Role-Specific Dashboard -->
                <li class="nav-item member-only" onclick="switchPage('dashboard')"><i
                        data-lucide="layout-dashboard"></i> Dashboard</li>
                <li class="nav-item admin-only" onclick="switchPage('admin-dashboard')"><i
                        data-lucide="layout-dashboard"></i> Dashboard</li>
                <li class="nav-item trainer-only" onclick="switchPage('trainer-dashboard')"><i
                        data-lucide="layout-dashboard"></i> Trainer Hub</li>
                <li class="nav-item trainer-only" onclick="switchPage('weekly-schedule')"><i
                        data-lucide="calendar-days"></i> Weekly Schedule</li>

                <li class="nav-item member-only" onclick="switchPage('booking')"><i data-lucide="calendar"></i> Book
                    Slot</li>
                <li class="nav-item member-only" onclick="switchPage('member-membership')"><i
                        data-lucide="credit-card"></i> My Membership</li>
                <li class="nav-item member-only" onclick="switchPage('member-weekly-workout')"><i
                        data-lucide="calendar-days"></i> Weekly Plan</li>
                <li class="nav-item member-only" onclick="switchPage('profile')"><i data-lucide="user"></i> Profile</li>
                <li class="nav-item member-only" onclick="switchPage('notifications')"><i data-lucide="bell"></i>
                    Notifications</li>

                <li class="nav-item admin-only" onclick="switchPage('admin-members')"><i data-lucide="users"></i>
                    Members</li>
                <li class="nav-item admin-only" onclick="switchPage('admin-memberships')"><i data-lucide="award"></i>
                    Memberships</li>
                <li class="nav-item admin-only" onclick="switchPage('admin-payments')"><i data-lucide="dollar-sign"></i>
                    Payments</li>
                <li class="nav-item admin-only" onclick="switchPage('admin-trainers')"><i data-lucide="briefcase"></i>
                    Trainers</li>
                <li class="nav-item admin-only" onclick="switchPage('admin-machines')"><i data-lucide="cpu"></i>
                    Machines</li>
                <li class="nav-item admin-only" onclick="switchPage('admin-attendance')"><i
                        data-lucide="check-square"></i> Attendance</li>
                <li class="nav-item admin-only" onclick="switchPage('admin-settings')"><i data-lucide="settings"></i>
                    Settings</li>
                <li class="nav-item" onclick="logout()"><i data-lucide="log-out"></i> Logout</li>
            </ul>
        </nav>

        <main class="content-area">
            <!-- DASHBOARD -->
            <section id="dashboard" class="page-section active">
                <header>
                    <h1 id="welcomeText">Dragon Gym Dashboard</h1>
                    <p style="color: var(--text-dim);" id="userNameDisplay">Warrior: Guest</p>
                </header>

                <!-- Trainer Recommendation Banner -->
                <div id="trainerRecBanner" class="card"
                    style="display: none; background: linear-gradient(135deg, rgba(255, 62, 62, 0.1), rgba(255, 157, 0, 0.15)); border: 1px solid rgba(255, 62, 62, 0.25); margin-bottom: 2rem; align-items: center; justify-content: space-between; flex-direction: row; gap: 15px;">
                    <div>
