        async function addTrainer() {
            if (!currentUser || currentUser.role !== 'admin') { showToast('❌ Admin access required.'); return; }

            const name = document.getElementById('trainerName').value.trim();
            const phone = document.getElementById('trainerPhone').value.trim();
            const email = document.getElementById('trainerEmail').value.trim().toLowerCase();
            const spec = document.getElementById('trainerSpec').value.trim();
            const exp = document.getElementById('trainerExp').value.trim();
            const pass = document.getElementById('trainerPassword').value;
            const confirm = document.getElementById('trainerConfirmPassword').value;

            if (!name || !phone || !email || !pass || !confirm) {
                showToast('⚠️ Please fill all required fields.'); return;
            }
            if (pass.length < 6) {
                showToast('⚠️ Password must be at least 6 characters.'); return;
            }
            if (pass !== confirm) {
                showToast('⚠️ Passwords do not match.'); return;
            }

            let trainers = JSON.parse(localStorage.getItem('gym_trainers')) || [];

            const emailExists = trainers.some(t => t.email && t.email.toLowerCase() === email);
            const phoneExists = trainers.some(t => t.phone === phone);
            if (emailExists) { showToast('⚠️ A trainer with this email already exists.'); return; }
            if (phoneExists) { showToast('⚠️ A trainer with this phone already exists.'); return; }

            const newId = 'T' + String(trainers.length + 1).padStart(3, '0');
            const hashedPass = await hashPassword(pass);

            const newTrainer = {
                id: newId,
                name,
                phone,
                email,
                specialization: spec,
                experience: exp,
                password: hashedPass,
                createdAt: new Date().toISOString()
            };

            trainers.push(newTrainer);
            localStorage.setItem('gym_trainers', JSON.stringify(trainers));
            closeAddTrainerModal();
            renderAdminTrainers();
            showToast(`✅ Trainer "${name}" added successfully! Login: ${email} or ${phone}`);
        }

        async function saveEditTrainer() {
            if (!currentUser || currentUser.role !== 'admin') { showToast('❌ Admin access required.'); return; }

            const id = document.getElementById('editTrainerId').value;
            const name = document.getElementById('editTrainerName').value.trim();
            const phone = document.getElementById('editTrainerPhone').value.trim();
            const email = document.getElementById('editTrainerEmail').value.trim().toLowerCase();
            const spec = document.getElementById('editTrainerSpec').value.trim();
            const exp = document.getElementById('editTrainerExp').value.trim();
            const pass = document.getElementById('editTrainerPassword').value;
            const confirm = document.getElementById('editTrainerConfirmPassword').value;

            if (!name || !phone || !email) {
                showToast('⚠️ Name, Phone and Email are required.'); return;
            }
            if (pass && pass.length < 6) {
                showToast('⚠️ New password must be at least 6 characters.'); return;
            }
            if (pass && pass !== confirm) {
                showToast('⚠️ Passwords do not match.'); return;
            }

            let trainers = JSON.parse(localStorage.getItem('gym_trainers')) || [];
            const idx = trainers.findIndex(t => t.id === id);
            if (idx === -1) { showToast('Trainer not found.'); return; }

            const emailConflict = trainers.some((t, i) => i !== idx && t.email && t.email.toLowerCase() === email);
            const phoneConflict = trainers.some((t, i) => i !== idx && t.phone === phone);
            if (emailConflict) { showToast('⚠️ Another trainer already uses this email.'); return; }
            if (phoneConflict) { showToast('⚠️ Another trainer already uses this phone.'); return; }

            trainers[idx].name = name;
            trainers[idx].phone = phone;
            trainers[idx].email = email;
            trainers[idx].specialization = spec;
            trainers[idx].experience = exp;
            trainers[idx].updatedAt = new Date().toISOString();

            if (pass) {
                trainers[idx].password = await hashPassword(pass);
            }

            localStorage.setItem('gym_trainers', JSON.stringify(trainers));
            closeEditTrainerModal();
            renderAdminTrainers();
            showToast(`✅ Trainer "${name}" updated successfully.`);
        }

        function deleteTrainer(trainerId) {
            if (!currentUser || currentUser.role !== 'admin') { showToast('❌ Admin access required.'); return; }
            let trainers = JSON.parse(localStorage.getItem('gym_trainers')) || [];
            const t = trainers.find(x => x.id === trainerId);
            if (!t) { showToast('Trainer not found.'); return; }
            if (!confirm(`Delete trainer "${t.name}"? This action cannot be undone.`)) return;
            trainers = trainers.filter(x => x.id !== trainerId);
            localStorage.setItem('gym_trainers', JSON.stringify(trainers));
            renderAdminTrainers();
            showToast(`🗑️ Trainer "${t.name}" deleted.`);
        }

