        function deleteAdminAccount(id) {
            if (!currentUser || currentUser.role !== 'admin') return; // RBAC guard
            const target = adminAccounts.find(a => a.id === id);
            if (target && target.isSuperAdmin) {
                return showToast('⚠️ Cannot delete the Super Admin account!');
            }
            if (!confirm(`Remove admin account "${id}"? This cannot be undone.`)) return;
            adminAccounts = adminAccounts.filter(a => a.id !== id);
            localStorage.setItem('gym_admins', JSON.stringify(adminAccounts));
            showToast('Admin account removed.');
            renderAdminAccountsList();
        }

        function renderAdminAccountsList() {
            adminAccounts = JSON.parse(localStorage.getItem('gym_admins')) || [];
            const container = document.getElementById('adminAccountsList');
            if (!container) return;
            container.innerHTML = '';
            if (adminAccounts.length === 0) {
                container.innerHTML = '<p style="color:var(--text-dim); font-size:0.85rem;">No admin accounts found.</p>';
                return;
