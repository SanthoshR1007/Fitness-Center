        function openAssignWorkoutModal(memberId) {
            if (!currentUser || currentUser.role !== 'trainer') {
                showToast('❌ Only trainers can assign workouts.');
                return;
            }
            const member = members.find(m => m.id == memberId);
            if (!member) {
                showToast('Member not found.');
                return;
            }

            document.getElementById('assignWorkoutMemberId').value = memberId;
            document.getElementById('assignWorkoutModalTitle').textContent = `Assign Routine: ${member.name}`;

            // Fetch today's workout if already assigned
            const today = new Date().toISOString().split('T')[0];
            const workouts = JSON.parse(localStorage.getItem('gym_workout_assignments')) || [];
            const existing = workouts.find(w => w.memberId == memberId && w.date === today);

            if (existing) {
                document.getElementById('assignWorkoutType').value = existing.workoutType || 'Chest';
                document.getElementById('assignWorkoutDetails').value = existing.workoutDetails || '';
                document.getElementById('assignWorkoutExercises').value = existing.exercises || '';
                document.getElementById('assignWorkoutSetsReps').value = existing.setsReps || '';
                document.getElementById('assignWorkoutDuration').value = existing.duration || '';
                document.getElementById('assignWorkoutNotes').value = existing.notes || '';
            } else {
                document.getElementById('assignWorkoutType').value = 'Chest';
                document.getElementById('assignWorkoutDetails').value = '';
                document.getElementById('assignWorkoutExercises').value = '';
                document.getElementById('assignWorkoutSetsReps').value = '';
                document.getElementById('assignWorkoutDuration').value = '';
                document.getElementById('assignWorkoutNotes').value = '';
            }

            document.getElementById('assignWorkoutModal').style.display = 'flex';
        }

        function closeAssignWorkoutModal() {
            document.getElementById('assignWorkoutModal').style.display = 'none';
        }

        function assignWorkout() {
            if (!currentUser || currentUser.role !== 'trainer') {
                showToast('❌ Only trainers can assign workouts.');
                return;
            }

            const memberId = document.getElementById('assignWorkoutMemberId').value;
            const workoutType = document.getElementById('assignWorkoutType').value;
            const details = document.getElementById('assignWorkoutDetails').value.trim();
            const exercises = document.getElementById('assignWorkoutExercises').value.trim();
            const setsReps = document.getElementById('assignWorkoutSetsReps').value.trim();
            const duration = document.getElementById('assignWorkoutDuration').value.trim();
            const notes = document.getElementById('assignWorkoutNotes').value.trim();

            if (!details || !exercises) {
                showToast('⚠️ Workout details and exercises are required.');
                return;
            }

            const today = new Date().toISOString().split('T')[0];
            let workouts = JSON.parse(localStorage.getItem('gym_workout_assignments')) || [];

            // Check if we are modifying/updating or creating new
            const existingIdx = workouts.findIndex(w => w.memberId == memberId && w.date === today);

            const trainerName = currentUser.name || 'Trainer';
            const trainerId = currentUser.trainerId || 'T000';

            const assignment = {
                id: existingIdx !== -1 ? workouts[existingIdx].id : 'WA_' + Date.now(),
                memberId: memberId,
                trainerId: trainerId,
                trainerName: trainerName,
                workoutType: workoutType,
                workoutDetails: details,
                exercises: exercises,
                setsReps: setsReps,
                duration: duration,
                notes: notes,
                date: today,
                status: existingIdx !== -1 ? workouts[existingIdx].status : 'Pending',
                updatedAt: new Date().toISOString()
            };

            if (existingIdx !== -1) {
                workouts[existingIdx] = assignment;
            } else {
                workouts.push(assignment);
            }
            localStorage.setItem('gym_workout_assignments', JSON.stringify(workouts));

            // Sync with assignedWorkout category on members list (for recommendation banner check)
            const mIdx = members.findIndex(m => m.id == memberId);
            if (mIdx !== -1) {
                members[mIdx].assignedWorkout = workoutType + " Day"; // e.g. "Chest Day", "Back Day"
                localStorage.setItem('gym_members', JSON.stringify(members));
            }

            // Create notification for Member
            let notifications = JSON.parse(localStorage.getItem('gym_notifications')) || [];
            const notif = {
                id: 'NT_' + Date.now(),
                memberId: memberId,
                title: existingIdx !== -1 ? 'Workout Plan Updated!' : 'New Workout Assigned!',
                message: `Trainer ${trainerName} has ${existingIdx !== -1 ? 'modified' : 'assigned'} your workout routine (${workoutType}) for today.`,
                workoutId: assignment.id,
                trainerName: trainerName,
                workoutDetails: details,
                workoutType: workoutType,
                date: today,
                createdAt: new Date().toISOString()
            };
            notifications.push(notif);
            localStorage.setItem('gym_notifications', JSON.stringify(notifications));

            // If logged in as the member affected, update session data
            if (currentUser && currentUser.role === 'member' && currentUser.data.id == memberId) {
                currentUser.data.assignedWorkout = workoutType + " Day";
                localStorage.setItem('gym_session', JSON.stringify(currentUser));
            }

            // Trigger local sync immediately (so UI updates in same tab)
            window.dispatchEvent(new Event('storage_sync_local'));

            closeAssignWorkoutModal();
            updateTrainerPanels();
            showToast('✅ Workout assigned and member notified!');
        }

        function toggleWorkoutCompletion(assignmentId) {
            let workouts = JSON.parse(localStorage.getItem('gym_workout_assignments')) || [];
            const idx = workouts.findIndex(w => w.id === assignmentId);
            if (idx === -1) return;

            const currentStatus = workouts[idx].status || 'Pending';
            const newStatus = currentStatus === 'Completed' ? 'Pending' : 'Completed';
            workouts[idx].status = newStatus;

            localStorage.setItem('gym_workout_assignments', JSON.stringify(workouts));

            showToast(newStatus === 'Completed' ? '🎉 Workout marked as Completed! Great job!' : 'Workout marked as Pending.');
            updateMemberDashboardWorkout();
        }

        function updateMemberDashboardWorkout() {
            if (!currentUser || currentUser.role !== 'member') return;

            const box = document.getElementById('memberAssignedWorkoutBox');
            if (!box) return;

            const today = new Date().toISOString().split('T')[0];
            const workouts = JSON.parse(localStorage.getItem('gym_workout_assignments')) || [];
            const todayWorkout = workouts.find(w => w.memberId == currentUser.data.id && w.date === today);

            if (!todayWorkout) {
                box.innerHTML = `
                    <div style="text-align: center; padding: 2rem; color: var(--text-dim);">
                        <i data-lucide="info" style="width: 36px; height: 36px; margin-bottom: 10px; color: var(--text-dim); opacity: 0.5;"></i>
                        <p>No workout plan has been assigned for today yet.</p>
                        <p style="font-size: 0.8rem; margin-top: 5px;">Your trainer will recommend a routine shortly.</p>
                    </div>
                `;
                lucide.createIcons();
                return;
            }

            const isCompleted = todayWorkout.status === 'Completed';

            box.innerHTML = `
                <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--card-border); padding: 1.5rem; border-radius: 16px; display: flex; flex-direction: column; gap: 12px;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; flex-wrap: wrap;">
                        <div>
                            <span style="background: rgba(255, 62, 62, 0.15); color: var(--primary); font-size: 0.75rem; font-weight: 700; padding: 4px 10px; border-radius: 12px; text-transform: uppercase;">
                                ${todayWorkout.workoutType} Focus
                            </span>
                            <h4 style="font-size: 1.25rem; margin-top: 6px; font-weight: 700; color: var(--text-main);">${todayWorkout.workoutDetails}</h4>
                            <p style="font-size: 0.85rem; color: var(--text-dim); margin-top: 2px;">Assigned by: <span style="color: var(--secondary); font-weight: 600;">${todayWorkout.trainerName}</span></p>
                        </div>
                        <div style="text-align: right;">
                            <span style="font-size: 0.8rem; color: var(--text-dim);">${todayWorkout.date}</span>
                        </div>
                    </div>

                    <div style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); padding: 12px; border-radius: 12px;">
                        <h5 style="font-size: 0.85rem; color: var(--primary); margin-bottom: 6px; font-weight: 600;">Exercises Checklist:</h5>
                        <p style="white-space: pre-line; font-size: 0.9rem; line-height: 1.5; color: var(--text-main);">${todayWorkout.exercises}</p>
                    </div>

                    <div style="display: flex; gap: 12px; flex-wrap: wrap;">
                        ${todayWorkout.setsReps ? `
                            <div style="flex: 1; min-width: 120px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 8px 12px; border-radius: 10px;">
                                <span style="font-size: 0.75rem; color: var(--text-dim); display: block;">Sets & Reps</span>
                                <span style="font-size: 0.88rem; font-weight: 600; color: var(--text-main);">${todayWorkout.setsReps}</span>
                            </div>
                        ` : ''}
                        ${todayWorkout.duration ? `
                            <div style="flex: 1; min-width: 120px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 8px 12px; border-radius: 10px;">
                                <span style="font-size: 0.75rem; color: var(--text-dim); display: block;">Duration</span>
                                <span style="font-size: 0.88rem; font-weight: 600; color: var(--text-main);">${todayWorkout.duration}</span>
                            </div>
                        ` : ''}
                    </div>

                    ${todayWorkout.notes ? `
                        <p style="font-size: 0.82rem; color: var(--text-dim); font-style: italic; background: rgba(255, 157, 0, 0.05); border-left: 3px solid var(--secondary); padding: 6px 12px; border-radius: 4px;">
                            <strong>Note:</strong> ${todayWorkout.notes}
                        </p>
                    ` : ''}

                    <button class="btn-primary" style="margin-top: 10px; width: 100%; border-radius: 12px; font-weight: 700; transition: 0.3s;
                        background: ${isCompleted ? 'linear-gradient(135deg, #00ff80, #00aa50)' : 'linear-gradient(135deg, var(--primary), #b30000)'};
                        color: ${isCompleted ? '#000' : '#fff'};"
                        onclick="toggleWorkoutCompletion('${todayWorkout.id}')">
                        ${isCompleted ? '✓ Completed! (Click to redo)' : 'Mark Workout as Completed'}
                    </button>
                </div>
            `;
            lucide.createIcons();
        }

        function requestNotificationPermission() {
            if ('Notification' in window) {
                if (Notification.permission === 'default') {
                    Notification.requestPermission();
                }
            }
        }

        function showNativePushNotification(notifData) {
            if ('Notification' in window && Notification.permission === 'granted') {
                const timeStr = new Date(notifData.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                const title = `💪 ${notifData.title}`;
                const options = {
                    body: `${notifData.message}\nCategory: ${notifData.workoutType}\nDetails: ${notifData.workoutDetails}\nTrainer: ${notifData.trainerName}\nDate: ${notifData.date} at ${timeStr}`,
                    icon: './dragon_gym_icon.png',
                    badge: './dragon_gym_icon.png',
                    tag: notifData.id,
                    requireInteraction: true
                };
                new Notification(title, options);
            }
        }

        // storage / sync event listener for real-time push notifications
        function syncMemberRealtimeNotifications() {
            if (!currentUser || currentUser.role !== 'member') return;

            // Load and refresh state
            updateNotificationsList();
            updateMemberDashboardWorkout();

            const notifications = JSON.parse(localStorage.getItem('gym_notifications')) || [];
            const myNotifs = notifications.filter(n => n.memberId == currentUser.data.id);
            if (myNotifs.length > 0) {
                const latest = myNotifs[myNotifs.length - 1];
                const lastAlertedId = sessionStorage.getItem('last_alerted_notification_id');
                if (lastAlertedId !== latest.id) {
                    sessionStorage.setItem('last_alerted_notification_id', latest.id);

                    // Show standard toast
                    showToast(`🔔 ${latest.title}: ${latest.message}`);

                    // Show native push notification
                    showNativePushNotification(latest);
                }
            }
        }

        // Register event listeners for sync
        window.addEventListener('storage', (event) => {
            if (event.key === 'gym_notifications' || event.key === 'gym_workout_assignments') {
                syncMemberRealtimeNotifications();
            }
        });
        window.addEventListener('storage_sync_local', () => {
            syncMemberRealtimeNotifications();
        });

        function updateNotificationsList() {
            if (!currentUser || currentUser.role !== 'member') return;

            const notifications = JSON.parse(localStorage.getItem('gym_notifications')) || [];
            const userNotifs = notifications.filter(n => n.memberId == currentUser.data.id)
                .sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));

            const dashboardFeed = document.getElementById('memberDashboardNotificationsFeed');
            const pageList = document.getElementById('notificationsPageList');

            // 1. Render Dashboard Feed
            if (dashboardFeed) {
                if (userNotifs.length === 0) {
                    dashboardFeed.innerHTML = '<p style="color: var(--text-dim); font-size: 0.9rem; text-align: center; padding: 1rem;">No notifications yet.</p>';
                } else {
                    dashboardFeed.innerHTML = userNotifs.slice(0, 5).map(n => {
                        const timeStr = new Date(n.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                        return `
                            <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--card-border); padding: 10px 14px; border-radius: 12px; display: flex; flex-direction: column; gap: 4px;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="font-weight: 700; font-size: 0.85rem; color: var(--secondary);">${n.title}</span>
                                    <span style="font-size: 0.7rem; color: var(--text-dim);">${n.date} ${timeStr}</span>
                                </div>
                                <p style="font-size: 0.8rem; color: var(--text-main); margin: 0;">${n.message}</p>
                                <p style="font-size: 0.72rem; color: var(--text-dim); margin: 0; font-style: italic;">
                                    Cat: ${n.workoutType || 'N/A'} | Details: ${n.workoutDetails || 'N/A'} | By: ${n.trainerName || 'N/A'}
                                </p>
                            </div>
                        `;
                    }).join('');
                }
            }

            // 2. Render Notifications Page History
            if (pageList) {
                if (userNotifs.length === 0) {
                    pageList.innerHTML = `
                        <div style="text-align: center; padding: 3rem; color: var(--text-dim);">
                            <i data-lucide="bell-off" style="width: 48px; height: 48px; margin-bottom: 15px; opacity: 0.5;"></i>
                            <p style="font-size: 1.1rem; font-weight: 600;">No notifications found</p>
                            <p style="font-size: 0.85rem; margin-top: 5px;">Whenever a trainer assigns or edits your workout plan, you'll receive updates here immediately.</p>
                        </div>
                    `;
                } else {
                    pageList.innerHTML = userNotifs.map(n => {
                        const timeStr = new Date(n.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                        return `
                            <div style="background: rgba(255,255,255,0.03); border: 1px solid var(--card-border); padding: 1.5rem; border-radius: 16px; display: flex; flex-direction: column; gap: 8px; border-left: 4px solid var(--primary);">
                                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                                    <h4 style="color: var(--secondary); margin: 0; font-size: 1.1rem; font-weight: 700;">${n.title}</h4>
                                    <span style="font-size: 0.8rem; color: var(--text-dim);">${new Date(n.createdAt).toLocaleDateString()} ${timeStr}</span>
                                </div>
                                <p style="font-size: 0.95rem; color: var(--text-main); margin: 5px 0;">${n.message}</p>
                                <div style="background: rgba(0,0,0,0.15); padding: 10px 15px; border-radius: 8px; border: 1px dashed rgba(255,255,255,0.05); margin-top: 5px; font-size: 0.82rem; color: var(--text-dim); display: flex; flex-direction: column; gap: 4px;">
                                    <div><strong>Workout Category:</strong> <span style="color: var(--text-main);">${n.workoutType || 'N/A'}</span></div>
                                    <div><strong>Workout Details:</strong> <span style="color: var(--text-main);">${n.workoutDetails || 'N/A'}</span></div>
                                    <div><strong>Trainer Name:</strong> <span style="color: var(--text-main);">${n.trainerName || 'Trainer'}</span></div>
                                    <div><strong>Date & Time Assigned:</strong> <span style="color: var(--text-main);">${n.date} at ${timeStr}</span></div>
                                </div>
                            </div>
                        `;
                    }).join('');
                }
            }
            lucide.createIcons();
        }

        window.onload = () => {
            initDemoData();

            const savedSession = localStorage.getItem('gym_session');
            if (savedSession) {
                currentUser = JSON.parse(savedSession);
                startApp();
            } else {
                renderSavedAccounts();
            }

            const savedName = localStorage.getItem('gymName') || 'Dragon Gym';
            document.getElementById('adminGymName').value = savedName;
            updateBranding(true);

            const today = new Date().toISOString().split('T')[0];
            document.getElementById('bookingDate').value = today;

            document.getElementById('bookingDate').addEventListener('change', () => {
                if (bookingData.session) {
                    bookingData.time = '';
                    bookingData.machines = [];
                    updateTimeSlotsGrid();
                    document.getElementById('machineStep').style.display = 'none';
                }
            });

            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.register('./sw.js')
                    .then(reg => console.log('Service Worker Registered Successfully!', reg))
                    .catch(err => console.log('Service Worker Registration Failed:', err));
            }
        }
    </script>
</body>

</html>